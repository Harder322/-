@startuml
[*] --> Меню : /start

state Меню {
  [*] --> Ожидание
  Ожидание --> ПросмотрПар : Сегодня/Завтра/Неделя
  Ожидание --> СменаГруппы : Сменить группу
  Ожидание --> Настройки : Настройки
}

state ПросмотрПар {
  [*] --> Проверка
  Проверка --> Показ : группа есть
  Проверка --> ВводГруппы : группы нет
  ВводГруппы --> Показ : введено
}

ПросмотрПар --> Меню : готово
СменаГруппы --> Меню : группа обновлена
Настройки --> Меню : настройка выполнена
@enduml
