@startuml
left to right direction
actor "Пользователь" as User

rectangle "Telegram-бот расписания" {
  usecase "Просмотр расписания на сегодня" as UC1
  usecase "Просмотр расписания на завтра" as UC2
  usecase "Просмотр расписания на неделю" as UC3
  usecase "Сменить группу" as UC4
  usecase "Настройки" as UC5
  usecase "Вкл/выкл уведомления" as UC6
  usecase "Сбросить группу" as UC7
  usecase "Информация о боте" as UC8
  usecase "Выбор дня недели" as UC9

  UC3 ..> UC9 : <<extend>>
  UC5 ..> UC6 : <<include>>
  UC5 ..> UC7 : <<include>>
  UC5 ..> UC8 : <<include>>
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
@enduml
