@startuml
start
:Пользователь запускает бота /start;
:Бот приветствует и показывает главное меню;
repeat
  :Ожидание выбора действия;
  switch (Выбор)
  case (📅 Сегодня)
    :Проверить группу;
    if (группа сохранена?) then (да)
      :Запросить расписание на сегодня;
    else (нет)
      :Запросить ввод группы;
      :Сохранить группу;
      :Запросить расписание на сегодня;
    endif
    :Показать пары или сообщение об отсутствии;
  case (📆 Завтра)
    :Проверить группу;
    if (группа сохранена?) then (да)
      :Запросить расписание на завтра;
    else (нет)
      :Запросить ввод группы;
      :Сохранить группу;
      :Запросить расписание на завтра;
    endif
    :Показать пары или сообщение об отсутствии;
  case (🗓 Неделя)
    :Проверить группу;
    if (группа сохранена?) then (да)
      :Показать дни недели;
    else (нет)
      :Запросить ввод группы;
      :Сохранить группу;
      :Показать дни недели;
    endif
    :Пользователь выбирает день;
    :Показать расписание на выбранный день;
  case (👥 Сменить группу)
    :Запросить новую группу;
    if (группа существует?) then (да)
      :Обновить группу в профиле;
    else (нет)
      :Сообщить об ошибке;
      :Запросить новую группу;
    endif
  case (⚙️ Настройки)
    :Показать меню настроек;
    switch (Подвыбор)
    case (Уведомления)
      :Вкл/выкл напоминания;
    case (Сбросить группу)
      :Удалить сохранённую группу;
    case (О боте)
      :Показать информацию;
    endswitch
  endswitch
  :Предложить вернуться в меню;
repeat while (Пользователь не завершил сеанс)
stop
@enduml
