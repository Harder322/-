from datetime import date, time
from typing import List, Optional

class User:
    def __init__(self, user_id: int, username: str, group_number: Optional[str] = None):
        self.user_id = user_id
        self.username = username
        self.group_number = group_number
        self.notifications_enabled = True

    def get_group(self) -> Optional[str]:
        return self.group_number

    def set_group(self, group: str) -> None:
        self.group_number = group

    def toggle_notifications(self) -> None:
        self.notifications_enabled = not self.notifications_enabled


class Lesson:
    def __init__(self, id: int, schedule_id: int, start_time: time, end_time: time,
                 subject: str, lesson_type: str, teacher: str, room: str):
        self.id = id
        self.schedule_id = schedule_id
        self.start_time = start_time
        self.end_time = end_time
        self.subject = subject
        self.lesson_type = lesson_type
        self.teacher = teacher
        self.room = room


