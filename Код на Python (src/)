import logging
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import Application, CommandHandler, CallbackQueryHandler, MessageHandler, filters, ContextTypes
from models import User

# Настройка логирования
logging.basicConfig(format='%(asctime)s - %(name)s - %(levelname)s - %(message)s', level=logging.INFO)
logger = logging.getLogger(__name__)

# Хранилище пользователей (в реальном проекте — БД)
users = {}

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    user_id = update.effective_user.id
    if user_id not in users:
        users[user_id] = User(user_id, update.effective_user.username)
    
    keyboard = [
        [InlineKeyboardButton("📅 Сегодня", callback_data='today')],
        [InlineKeyboardButton("📆 Завтра", callback_data='tomorrow')],
        [InlineKeyboardButton("🗓 Неделя", callback_data='week')],
        [InlineKeyboardButton("👥 Сменить группу", callback_data='change_group')],
        [InlineKeyboardButton("⚙️ Настройки", callback_data='settings')],
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    await update.message.reply_text('Добро пожаловать! Выберите действие:', reply_markup=reply_markup)

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    query = update.callback_query
    await query.answer()
    user_id = update.effective_user.id
    user = users.get(user_id)
    
    if not user:
        await query.edit_message_text("Ошибка: пользователь не найден. Введите /start")
        return
    
    data = query.data
    
    if data in ('today', 'tomorrow', 'week'):
        if user.get_group() is None:
            await query.edit_message_text("Сначала укажите номер группы через меню «Сменить группу»")
        else:
            await query.edit_message_text(f"Расписание {data} для группы {user.get_group()} (заглушка)")
    
    elif data == 'change_group':
        await query.edit_message_text("Введите номер группы:")
        context.user_data['awaiting_group'] = True
    
    elif data == 'settings':
        await query.edit_message_text("Настройки: уведомления, сброс группы (заглушка)")
    
    # Восстановление меню после ответа
    # Здесь можно вернуть клавиатуру

async def message_handler(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    user_id = update.effective_user.id
    user = users.get(user_id)
    text = update.message.text
    
    if context.user_data.get('awaiting_group'):
        user.set_group(text)
        context.user_data['awaiting_group'] = False
        await update.message.reply_text(f"Группа {text} сохранена!")
    else:
        await update.message.reply_text("Используйте кнопки меню. /start для начала.")

def main() -> None:
    application = Application.builder().token("YOUR_TOKEN_HERE").build()
    
    application.add_handler(CommandHandler("start", start))
    application.add_handler(CallbackQueryHandler(button_handler))
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, message_handler))
    
    application.run_polling()

if __name__ == '__main__':
    main()
